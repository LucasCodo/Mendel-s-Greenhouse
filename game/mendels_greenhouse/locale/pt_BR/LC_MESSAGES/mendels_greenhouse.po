#: mendels_greenhouse/scenes/main_game.py:224
msgid "Visible traits are what you can observe on a plant."
msgstr "Tracos visiveis sao o que voce observa em uma planta."

#: mendels_greenhouse/scenes/main_game.py:227
msgid "A dominant allele can shape the visible trait when present."
msgstr "Um alelo dominante pode definir o traco visivel quando esta presente."

#: mendels_greenhouse/scenes/main_game.py:230
msgid "A recessive allele appears only when no dominant allele masks it."
msgstr "Um alelo recessivo aparece apenas quando nenhum alelo dominante o mascara."

#: mendels_greenhouse/scenes/main_game.py:233
msgid "Each gene is represented by two alleles, one from each parent."
msgstr "Cada gene e representado por dois alelos, um de cada progenitor."

#: mendels_greenhouse/scenes/main_game.py:236
msgid "A genotype records the allele pair for each tracked gene."
msgstr "Um genotipo registra o par de alelos de cada gene acompanhado."

#: mendels_greenhouse/scenes/main_game.py:239
msgid "A homozygous gene has two matching alleles."
msgstr "Um gene homozigoto possui dois alelos iguais."

#: mendels_greenhouse/scenes/main_game.py:242
msgid "A heterozygous gene has two different alleles."
msgstr "Um gene heterozigoto possui dois alelos diferentes."

#: mendels_greenhouse/scenes/main_game.py:245
msgid "Parents pass one allele from each gene to each offspring."
msgstr "Os progenitores passam um alelo de cada gene para cada descendente."

#: mendels_greenhouse/scenes/main_game.py:248
msgid "Different genes can be inherited independently."
msgstr "Genes diferentes podem ser herdados independentemente."

#: mendels_greenhouse/scenes/main_game.py:251
msgid "AaBb x AaBb can produce four phenotype classes."
msgstr "AaBb x AaBb pode produzir quatro classes de fenotipos."

#: mendels_greenhouse/scenes/main_game.py:254
msgid "Expected percentages help plan before breeding."
msgstr "As porcentagens esperadas ajudam a planejar antes do cruzamento."

#: mendels_greenhouse/scenes/main_game.py:257
msgid "Planning compares crosses against a target result."
msgstr "O planejamento compara cruzamentos com um resultado-alvo."

